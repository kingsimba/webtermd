[Unit]
Description=ax-term Web Terminal
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=robot
WorkingDirectory=/home/robot
ExecStart=/opt/ax-term/ax-term --addr=:8080
Restart=always
RestartSec=5

# Security hardening
# NoNewPrivileges=yes
# PrivateTmp=yes
# ProtectSystem=strict
# ReadWritePaths=/home/robot/.ssh /home/robot/.ax-term-uploads

[Install]
WantedBy=multi-user.target
