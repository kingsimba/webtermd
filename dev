#!/usr/bin/env python3
"""Build script for webtermd — native or cross-compiled static binary."""

import argparse
import os
import shutil
import subprocess
import sys

PROJECT_ROOT = os.path.dirname(os.path.abspath(__file__))


def run(cmd, **kwargs):
    print(f"  {' '.join(cmd)}")
    subprocess.run(cmd, check=True, cwd=PROJECT_ROOT, **kwargs)


def cmd_build(args):
    goos = "linux"
    goarch = args.arm64 and "arm64" or "amd64"
    output = "bin/webtermd-arm64" if args.arm64 else "bin/webtermd"

    env = os.environ.copy()
    env["GOOS"] = goos
    env["GOARCH"] = goarch
    env["CGO_ENABLED"] = "0"

    if args.arm64:
        env["GOARM"] = "7"

    print(f"Building for {goos}/{goarch} → {output}")
    run(
        ["go", "build", "-ldflags=-s -w", "-o", output, "./cmd/server"],
        env=env,
    )

    # Copy static files alongside the binary
    dest_dir = os.path.join(PROJECT_ROOT, "bin")
    static_dest = os.path.join(dest_dir, "static")
    if os.path.exists(static_dest):
        shutil.rmtree(static_dest)
    shutil.copytree(os.path.join(PROJECT_ROOT, "static"), static_dest)

    print(f"Done: {output} (with static/)")


def cmd_clean(args):
    bindir = os.path.join(PROJECT_ROOT, "bin")
    if os.path.exists(bindir):
        shutil.rmtree(bindir)
        print(f"Removed {bindir}")
    else:
        print("Nothing to clean")


def cmd_test(args):
    cmd = ["go", "test"]
    if args.verbose:
        cmd.append("-v")
    if args.count:
        cmd.extend(["-count", str(args.count)])
    if args.run:
        cmd.extend(["-run", args.run])
    if args.race:
        cmd.append("-race")
    cmd.append("./...")
    run(cmd)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Build and test webtermd")
    sub = parser.add_subparsers(dest="command", required=True)

    # build
    build_parser = sub.add_parser("build", help="Build the binary")
    build_parser.add_argument(
        "--arm64", action="store_true", help="Cross-compile for ARM64"
    )
    build_parser.set_defaults(func=cmd_build)

    # test
    test_parser = sub.add_parser("test", help="Run tests")
    test_parser.add_argument(
        "-v", "--verbose", action="store_true", help="Verbose output"
    )
    test_parser.add_argument(
        "-c", "--count", type=int, default=1, help="Run count (default: 1)"
    )
    test_parser.add_argument(
        "-r", "--run", type=str, help="Run only tests matching pattern"
    )
    test_parser.add_argument("--race", action="store_true", help="Enable race detector")
    test_parser.set_defaults(func=cmd_test)

    # clean
    clean_parser = sub.add_parser("clean", help="Remove build artifacts")
    clean_parser.set_defaults(func=cmd_clean)

    args = parser.parse_args()

    if args.command == "build":
        os.makedirs(os.path.join(PROJECT_ROOT, "bin"), exist_ok=True)

    args.func(args)
